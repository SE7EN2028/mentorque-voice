# Neon connection strings — copy both from your Neon project's "Connect" dialog.
# DATABASE_URL: pooled connection (via PgBouncer), used by the app at runtime.
# DIRECT_URL:   unpooled connection, used only by Prisma Migrate.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"
