// Two connection strings are configured on purpose: Neon's pooled connection
// (routed through PgBouncer) doesn't reliably support the advisory locks
// Prisma Migrate needs, so migrations run through the direct, unpooled URL
// while the app itself queries through the pooled one.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Keep these values in sync with ExperienceLevel in
// packages/shared/src/auth/experience-level.ts — Prisma's schema DSL can't
// import that TS union, so it's duplicated by hand.
enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String          @map("password_hash")
  name            String
  jobRole         String          @map("job_role")
  experienceLevel ExperienceLevel @map("experience_level")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  sessions InterviewSession[]

  @@map("users")
}

// Keep these values in sync with InterviewType/SessionStatus in
// packages/shared/src/sessions — same manual-sync caveat as ExperienceLevel.
enum InterviewType {
  BEHAVIORAL
  TECHNICAL
  SYSTEM_DESIGN
  HR_CULTURE_FIT
}

enum SessionStatus {
  CREATED
  ACTIVE
  CLOSING
  COMPLETED
  ABANDONED
}

model InterviewSession {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  interviewType InterviewType @map("interview_type")
  status        SessionStatus @default(CREATED)

  resumeContext         String? @map("resume_context")
  jobDescriptionContext String? @map("job_description_context")

  // engineState holds the conversation engine's EngineState (including the
  // nested ConversationMemory) as defined in packages/interview-engine —
  // opaque jsonb here, typed and Zod-validated on the way in/out there.
  engineState Json? @map("engine_state") @db.JsonB
  // metadata carries voice-session bookkeeping (sttProvider, ttsProvider) once
  // a voice interview starts — reserved since Phase 2, first used in Phase 5.
  metadata    Json? @db.JsonB

  // Set once a voice session starts (apps/agent-worker). Deliberately
  // deferred until this phase — Phase 2 explicitly left LiveKit out of
  // scope, so this column didn't exist until it was actually needed.
  livekitRoomName String? @map("livekit_room_name")

  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcriptTurns TranscriptTurn[]
  feedbackReport  FeedbackReport?

  @@index([userId])
  @@map("interview_sessions")
}

enum TurnRole {
  INTERVIEWER
  CANDIDATE
}

// Keep these values in sync with TURN_ACTIONS in
// packages/shared/src/interviews/turn-action.ts.
enum TurnAction {
  FOLLOW_UP
  PROBE
  CHALLENGE
  ADVANCE_TOPIC
  CONCLUDE
}

model TranscriptTurn {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  sequence  Int
  role      TurnRole
  content   String

  // Only set on CANDIDATE turns — the 8-dimension AnswerEvaluation from
  // packages/interview-engine, nullable per dimension by interview type.
  evaluation Json? @db.JsonB

  // Only set on INTERVIEWER turns.
  actionTaken      TurnAction? @map("action_taken")
  difficultyAtTurn Int?        @map("difficulty_at_turn")

  createdAt DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sequence])
  @@map("transcript_turns")
}

model FeedbackReport {
  id        String @id @default(cuid())
  sessionId String @unique @map("session_id")

  // All four below are fully deterministic (computed in code from
  // evaluationHistory/blueprint/transcript, never asked of the LLM) — see
  // packages/feedback-engine/src/deterministic-metrics.ts.
  overallScore          Int   @map("overall_score")
  dimensionScores       Json  @map("dimension_scores") @db.JsonB
  topicCoverage         Json  @map("topic_coverage") @db.JsonB
  difficultyReached     Int   @map("difficulty_reached")
  difficultyProgression Int[] @map("difficulty_progression")
  durationMs            Int   @map("duration_ms")

  // Everything below is the LLM's qualitative writing, grounded in the
  // deterministic numbers above via the report prompt.
  summary                  String
  topStrengths             String[] @map("top_strengths")
  areasForImprovement      String[] @map("areas_for_improvement")
  missedOpportunities      String[] @map("missed_opportunities")
  recommendedNextSteps     String[] @map("recommended_next_steps")
  actionablePracticeAdvice String[] @map("actionable_practice_advice")

  createdAt DateTime @default(now()) @map("created_at")

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("feedback_reports")
}
