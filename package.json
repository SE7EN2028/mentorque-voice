{
  "name": "mentorque",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup-env.mjs && npm run build -w packages/shared && npm run build -w packages/db",
    "dev": "concurrently -n shared,db,server,client -c yellow,magenta,green,blue \"npm:dev:shared\" \"npm:dev:db\" \"npm:dev:server\" \"npm:dev:client\"",
    "dev:shared": "npm run dev -w packages/shared",
    "dev:db": "npm run dev -w packages/db",
    "dev:server": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "build": "npm run build -w packages/shared && npm run build -w packages/db && npm run build -w apps/server && npm run build -w apps/client",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run generate -w packages/db",
    "db:migrate": "npm run migrate -w packages/db",
    "db:push": "npm run push -w packages/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
