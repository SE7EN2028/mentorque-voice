PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=changeme-generate-a-real-secret

# Neon connection strings — same values as packages/db/.env. The server
# imports @mentorque/db and queries Prisma directly in-process, so it needs
# its own copy of these in its own env (dotenv only loads the .env in this
# app's own directory, not packages/db's).
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# LLM_PROVIDER=groq (default) | openrouter | gemini — picks the conversation
# engine's LLM backend. Groq needs GROQ_API_KEY (+ optional GROQ_MODEL);
# OpenRouter needs OPENROUTER_API_KEY (+ optional OPENROUTER_MODEL);
# Gemini needs GEMINI_API_KEY.
LLM_PROVIDER=groq
GROQ_API_KEY=
# Any model from https://console.groq.com/docs/models that supports JSON mode —
# switch here, no code changes needed.
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
# Comma-separated = OpenRouter fallback chain (free-tier pools 429 transiently)
OPENROUTER_MODEL=openai/gpt-oss-120b:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-3-super-120b-a12b:free
GEMINI_API_KEY=

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
