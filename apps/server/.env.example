PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=changeme-generate-a-real-secret

# Neon connection strings — same values as packages/db/.env. The server
# imports @mentorque/db and queries Prisma directly in-process, so it needs
# its own copy of these in its own env (dotenv only loads the .env in this
# app's own directory, not packages/db's).
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

GEMINI_API_KEY=
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
