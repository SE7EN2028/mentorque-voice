NODE_ENV=development

# The worker calls @mentorque/interview-session and @mentorque/interview-engine
# in-process, so it needs the same DB and Gemini credentials the REST server
# does — this process is its own deployable, not routed through Express.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"
GEMINI_API_KEY=

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

DEEPGRAM_API_KEY=

# TTS_PROVIDER=google (default, dev) | cartesia (lower latency, for demos)
TTS_PROVIDER=google
GOOGLE_API_KEY=
CARTESIA_API_KEY=
